---
import BaseLayout from '../layouts/BaseLayout.astro';
import { REPO_OWNER, REPO_NAME, VAGA_LABEL } from '../lib/github';

if (import.meta.env.ENABLE_AJUDA !== 'true') {
  return Astro.redirect(import.meta.env.BASE_URL);
}

const postUrl = `https://github.com/${REPO_OWNER}/${REPO_NAME}/issues/new?labels=${VAGA_LABEL}&template=vaga.yml`;
---
<BaseLayout title="Ajuda" activeSection="ajuda" breadcrumb="ajuda/README.md">

<div class="doc-shell">

  <div class="doc-tabs">
    <div class="dtab active"><span class="td md"></span>README.md</div>
  </div>

  <div class="doc-area">
    <div class="doc-gutter" id="doc-gutter"></div>
    <div class="doc-content" id="doc-content">

      <div class="page-header">
        <div class="md-h1"># Publicando uma Vaga</div>
        <div class="header-sub">Sem cadastro. Sem conta paga. Só preencher um formulário.</div>
      </div>
      <div class="md-blank"></div>

      <div class="steps-grid">

        <div class="step-card">
          <div class="step-num">01</div>
          <div class="step-body">
            <div class="step-title">Clique no botão abaixo</div>
            <div class="step-desc">Você será redirecionado para o GitHub — não precisa entender o que é, só seguir os passos.</div>
          </div>
        </div>

        <div class="step-arrow">→</div>

        <div class="step-card">
          <div class="step-num">02</div>
          <div class="step-body">
            <div class="step-title">Preencha o formulário</div>
            <div class="step-desc">Campos com <span class="req">*</span> são obrigatórios. Os demais são opcionais.</div>
          </div>
        </div>

        <div class="step-arrow">→</div>

        <div class="step-card">
          <div class="step-num">03</div>
          <div class="step-body">
            <div class="step-title">Clique em "Submit new issue"</div>
            <div class="step-desc">Aguarde ~1 minuto e a vaga aparece no site automaticamente.</div>
          </div>
        </div>

      </div>
      <div class="md-blank"></div>
      <div class="md-blank"></div>

      <div class="cta-block">
        <a href={postUrl} target="_blank" rel="noopener" class="cta-btn">
          <span class="cta-icon">+</span>
          <span class="cta-text">Publicar vaga agora</span>
          <span class="cta-hint">abre o GitHub</span>
        </a>
        <div class="cta-note">Gratuito · Sem cadastro · Aparece em ~1 minuto</div>
      </div>
      <div class="md-blank"></div>
      <div class="md-blank"></div>

      <div class="md-h3">### O que você vai preencher</div>
      <div class="md-blank"></div>

      <div class="md-fields">
        <div class="mf-row">
          <span class="mf-field">Empresa <span class="mf-req">*</span></span>
          <span class="mf-desc">Nome da empresa. Ex: <span class="md-code">Nubank</span></span>
        </div>
        <div class="mf-row">
          <span class="mf-field">Nível <span class="mf-req">*</span></span>
          <span class="mf-desc">Escolha na lista: <span class="md-code">Júnior</span> · <span class="md-code">Pleno</span> · <span class="md-code">Sênior</span> · <span class="md-code">Lead</span> · <span class="md-code">Especialista</span></span>
        </div>
        <div class="mf-row">
          <span class="mf-field">Área <span class="mf-req">*</span></span>
          <span class="mf-desc">Escolha na lista: <span class="md-code">Dev</span> · <span class="md-code">Business</span></span>
        </div>
        <div class="mf-row">
          <span class="mf-field">Tipo <span class="mf-req">*</span></span>
          <span class="mf-desc">Escolha na lista: <span class="md-code">Remoto</span> · <span class="md-code">Híbrido</span> · <span class="md-code">Presencial</span></span>
        </div>
        <div class="mf-row">
          <span class="mf-field">Localização <span class="mf-req">*</span></span>
          <span class="mf-desc">Cidade/Estado ou "Remoto BR". Ex: <span class="md-code">São Paulo/SP</span></span>
        </div>
        <div class="mf-row">
          <span class="mf-field">Salário</span>
          <span class="mf-desc">Faixa salarial ou "A combinar". Ex: <span class="md-code">R$ 10k–15k</span></span>
        </div>
        <div class="mf-row">
          <span class="mf-field">Stack <span class="mf-req">*</span></span>
          <span class="mf-desc">Tecnologias separadas por vírgula. Ex: <span class="md-code">React, TypeScript, Node.js</span></span>
        </div>
        <div class="mf-row">
          <span class="mf-field">Descrição <span class="mf-req">*</span></span>
          <span class="mf-desc">Sobre a empresa, responsabilidades, requisitos e benefícios</span>
        </div>
        <div class="mf-row">
          <span class="mf-field">Candidatura <span class="mf-req">*</span></span>
          <span class="mf-desc">Link ou e-mail para candidatura. Ex: <span class="md-code">https://empresa.com/vagas</span></span>
        </div>
        <div class="mf-row">
          <span class="mf-field">LinkedIn?</span>
          <span class="mf-desc">Selecione <span class="md-code">Sim</span> se a vaga está publicada no LinkedIn</span>
        </div>
        <div class="mf-row">
          <span class="mf-field">Internacional?</span>
          <span class="mf-desc">Selecione <span class="md-code">Sim</span> se aceita candidatos internacionais</span>
        </div>
      </div>
      <div class="md-hint"><span class="mf-req">*</span> campo obrigatório</div>
      <div class="md-blank"></div>
      <div class="md-blank"></div>

      <div class="close-block">
        <div class="md-h2">## Removendo uma vaga</div>
        <div class="md-blank"></div>
        <div class="md-p">Acesse o GitHub e <strong>feche a Issue</strong> correspondente à vaga. O site atualiza em ~1 minuto.</div>
      </div>

      <div style="height:4rem"></div>
    </div>
  </div>
</div>

</BaseLayout>

<style>
.doc-shell {
  display: flex; flex-direction: column;
  height: calc(100vh - 36px - 24px);
}

.doc-tabs {
  display: flex; background: var(--darker);
  border-bottom: 1px solid var(--border); height: 36px; flex-shrink: 0;
}
.dtab {
  display: flex; align-items: center; gap: 0.4rem;
  padding: 0 1rem; height: 100%;
  font-size: 0.65rem; color: var(--text);
  border-right: 1px solid var(--border);
  border-top: 2px solid var(--cyan);
  background: var(--black);
}
.td { width: 8px; height: 8px; border-radius: 50%; }
.td.md { background: #6b7280; }

.doc-area {
  display: flex; flex: 1; overflow: hidden;
}

.doc-gutter {
  width: 44px; background: var(--darker);
  border-right: 1px solid var(--border); flex-shrink: 0;
}

.doc-content {
  flex: 1; overflow-y: auto;
  padding: 1.5rem 3rem; max-width: 820px;
}

/* ── HEADER ─────────────────────────────── */
.page-header { margin-bottom: 0.25rem; }
.md-h1 { font-size: 1.3rem; font-weight: 700; color: var(--text); margin-bottom: 0.4rem; }
.header-sub { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.02em; }

/* ── STEPS ──────────────────────────────── */
.steps-grid {
  display: flex; align-items: center; gap: 0.75rem;
  flex-wrap: wrap;
}

.step-card {
  display: flex; gap: 0.9rem;
  background: var(--darker);
  border: 1px solid var(--border);
  border-top: 2px solid var(--green);
  padding: 1rem 1.1rem;
  flex: 1; min-width: 160px;
}

.step-num {
  font-size: 1.4rem; font-weight: 700;
  color: var(--muted2); line-height: 1;
  flex-shrink: 0; padding-top: 0.1rem;
  font-family: var(--display);
}

.step-title {
  font-size: 0.72rem; font-weight: 700;
  color: var(--text); margin-bottom: 0.35rem;
}
.step-desc {
  font-size: 0.65rem; color: #6a8aaa; line-height: 1.7;
}
.req { color: var(--red); }

.step-arrow {
  color: var(--green); font-size: 1rem; flex-shrink: 0;
}

/* ── CTA ────────────────────────────────── */
.cta-block {
  display: flex; flex-direction: column; gap: 0.6rem;
}

.cta-btn {
  display: inline-flex; align-items: center; gap: 0.9rem;
  background: transparent;
  border: 1px solid var(--green);
  color: var(--green);
  padding: 0.85rem 1.6rem;
  font-size: 0.8rem; font-weight: 700;
  letter-spacing: 0.05em;
  position: relative; overflow: hidden;
  transition: color 0.2s;
  max-width: fit-content;
}

.cta-btn::before {
  content: ''; position: absolute; inset: 0;
  background: var(--green); transform: translateX(-101%);
  transition: transform 0.22s; z-index: 0;
}
.cta-btn:hover { color: var(--black); }
.cta-btn:hover::before { transform: none; }
.cta-btn > * { position: relative; z-index: 1; }

.cta-icon {
  font-size: 1.1rem; line-height: 1;
  font-weight: 300;
}
.cta-text { font-size: 0.78rem; }
.cta-hint {
  font-size: 0.6rem; font-weight: 400;
  color: var(--muted); letter-spacing: 0.04em;
  border-left: 1px solid currentColor;
  padding-left: 0.9rem;
  transition: color 0.2s;
}
.cta-btn:hover .cta-hint { color: var(--black); }

.cta-note {
  font-size: 0.62rem; color: var(--muted);
  letter-spacing: 0.04em;
}

/* ── FIELDS TABLE ───────────────────────── */
.md-h2 {
  font-size: 0.85rem; font-weight: 700; color: var(--cyan);
  margin-bottom: 0.5rem; margin-top: 1rem;
}
.md-h3 {
  font-size: 0.78rem; font-weight: 700; color: var(--text);
  margin-bottom: 0.5rem; margin-top: 1rem;
}
.md-p { font-size: 0.75rem; line-height: 1.8; color: #8aacca; margin-bottom: 0.5rem; }
.md-p strong { color: var(--text); }
.md-blank { height: 0.5rem; }
.md-code {
  font-family: var(--font); background: var(--mid);
  border: 1px solid var(--border2); color: var(--cyan);
  padding: 0.1rem 0.4rem; font-size: 0.85em;
}

.md-fields {
  border: 1px solid var(--border); font-size: 0.72rem;
  margin-bottom: 0.25rem;
}
.mf-row {
  display: grid; grid-template-columns: 140px 1fr;
  padding: 0.45rem 0.8rem; gap: 1rem;
  border-bottom: 1px solid var(--border);
  align-items: baseline;
}
.mf-row:last-child { border: none; }
.mf-field { color: var(--text); font-weight: 600; }
.mf-req { color: var(--red, #f87171); font-size: 0.75em; }
.mf-desc { color: #8aacca; line-height: 1.6; }

.md-hint {
  font-size: 0.62rem; color: var(--muted); margin-bottom: 0.5rem;
}

/* ── CLOSE BLOCK ────────────────────────── */
.close-block {
  border-top: 1px solid var(--border);
  padding-top: 1rem;
  margin-top: 0.5rem;
}
</style>

<script>
  const content = document.getElementById('doc-content')!;
  const gutter  = document.getElementById('doc-gutter')!;
  const lineH   = 0.72 * 16 * 1.9;
  const count   = Math.ceil((content.scrollHeight || 600) / lineH) + 10;
  gutter.innerHTML = Array.from({length: Math.max(count, 40)}, (_, i) =>
    `<div style="font-size:0.6rem;color:var(--muted2);text-align:right;padding-right:0.6rem;line-height:${lineH}px">${i+1}</div>`
  ).join('');
  content.addEventListener('scroll', () => { gutter.scrollTop = content.scrollTop; });
</script>
