---
import BaseLayout from '../layouts/BaseLayout.astro';

if (import.meta.env.ENABLE_AJUDA !== 'true') {
  return Astro.redirect(import.meta.env.BASE_URL);
}
---
<BaseLayout title="Ajuda" activeSection="ajuda" breadcrumb="ajuda/sobre.ts">

<div class="contact-shell">

  <div class="ct-tabs">
    <div class="ctab active"><span class="td ts"></span>sobre.ts</div>
  </div>

  <div class="ct-area">
    <div class="ct-gutter" id="ct-gutter"></div>
    <div class="ct-content" id="ct-content">

      <span class="cl ch">// por que fiz esse site</span>
      <span class="cl"></span>

      <span class="cl">Criei o DevVagas para ajudar pessoas a encontrarem oportunidades na área de tecnologia sem depender de plataformas pesadas ou cheias de ruído — e ao mesmo tempo quis explorar uma ideia de infraestrutura simples ao extremo: sem banco de dados, sem backend, sem custo de servidor. As vagas vivem como Issues no GitHub e o site é gerado estaticamente a cada publicação. Simples por baixo dos panos, mas — espero — útil de verdade.</span>
      <span class="cl"></span>
      <span class="cl ch">// contato</span>
      <span class="cl"></span>
      <span class="cl">Caso precise de ajuda ou queira trocar uma ideia, me encontra no meu blog: <a class="cs" href="https://blog.whatwill.tech/about/" target="_blank" rel="noopener">blog.whatwill.tech/about</a></span>

      <div style="height:4rem"></div>

    </div>
  </div>
</div>

</BaseLayout>

<style>
.contact-shell {
  display: flex; flex-direction: column;
  height: calc(100vh - 36px - 24px);
}

.ct-tabs {
  display: flex; background: var(--darker);
  border-bottom: 1px solid var(--border); height: 36px; flex-shrink: 0;
}
.ctab {
  display: flex; align-items: center; gap: 0.4rem;
  padding: 0 1rem; height: 100%; font-size: 0.65rem; color: var(--text);
  border-right: 1px solid var(--border);
  border-top: 2px solid var(--purple);
  background: var(--black);
}
.td { width: 8px; height: 8px; border-radius: 50%; }
.td.ts { background: #3178c6; }

.ct-area { display: flex; flex: 1; overflow: hidden; }

.ct-gutter {
  width: 44px; background: var(--darker);
  border-right: 1px solid var(--border); flex-shrink: 0;
}

.ct-content {
  flex: 1; overflow-y: auto;
  padding: 1.5rem 2.5rem;
  display: flex; flex-direction: column;
}

.cl { font-size: 0.72rem; line-height: 1.9; display: block; white-space: pre-wrap; }
.cl.ch { color: var(--purple); font-style: italic; font-size: 0.8rem; margin-top: 0.5rem; }
.cs { color: #ce9178; text-decoration: none; transition: opacity 0.15s; }
.cs:hover { opacity: 0.7; }
</style>

<script>
  const content = document.getElementById('ct-content')!;
  const gutter  = document.getElementById('ct-gutter')!;
  const lineH   = 0.72 * 16 * 1.9;
  const count   = Math.ceil((content.scrollHeight || 400) / lineH) + 10;
  gutter.innerHTML = Array.from({length: Math.max(count, 40)}, (_, i) =>
    `<div style="font-size:0.6rem;color:var(--muted2);text-align:right;padding-right:0.6rem;line-height:${lineH}px">${i+1}</div>`
  ).join('');
  content.addEventListener('scroll', () => { gutter.scrollTop = content.scrollTop; });
</script>
