</style>

<script>
// ── URL param pre-filters ───────────────────────────────────────
const _p = new URLSearchParams(location.search);
const _q0      = _p.get('q') || '';
const _stacks  = (_p.get('stack')  || '').split(',').filter(Boolean).map(s => s.toLowerCase());
const _niveis  = (_p.get('nivel')  || '').split(',').filter(Boolean).map(s => s.toLowerCase());
const _modos   = (_p.get('modo')   || '').split(',').filter(Boolean).map(s => s.toLowerCase());
const _extras  = (_p.get('extras') || '').split(',').filter(Boolean).map(s => s.toLowerCase());

if (_q0) {
  const si = document.getElementById('search') as HTMLInputElement;
  if (si) si.value = _q0;
}

// ── Data embedded from server ──────────────────────────────────
const JOBS: Record<number, any> = {};

document.querySelectorAll<HTMLElement>('.job-row').forEach(row => {
  const id = Number(row.dataset.id);
  JOBS[id] = {
    id,
    title:   row.querySelector('.jr-title')?.textContent?.trim() ?? '',
    company: row.querySelector('.jr-company')?.textContent?.trim() ?? '',
  };
});

// ── Chart filter state ─────────────────────────────────────────
const top4Labels: string[] = (() => {
  try { return (JSON.parse(document.getElementById('chart-data')?.textContent ?? '{}') as any).top4 ?? []; }
  catch { return []; }
})();
const selectedMidFilters   = new Set<string>(); // 'internacional' | 'nacional'
const selectedInnerFilters = new Set<string>(); // 'linkedin' | 'outros'
let   selectedStackOthers  = false;

// ── Stack filter (UI) ───────────────────────────────────────────
const selectedStacks = new Set<string>();
let sfOpen = false;

function setSfOpen(open: boolean) {
  sfOpen = open;
  const body    = document.getElementById('sf-body')!;
  const chevron = document.getElementById('sf-chevron')!;
  body.style.display = open ? 'block' : 'none';
  chevron.classList.toggle('open', open);
}

function updateSfCount() {
  const el = document.getElementById('sf-sel-count');
  if (el) el.textContent = selectedStacks.size > 0 ? String(selectedStacks.size) : '';
}

function hasAnyArcSelection() {
  return selectedStacks.size > 0 || selectedMidFilters.size > 0 ||
         selectedInnerFilters.size > 0 || selectedStackOthers;
}

function syncArcVisuals() {
  const anySelected = hasAnyArcSelection();
  document.querySelectorAll<SVGPathElement>('.ws-arc').forEach(arc => {
    const arcId = arc.dataset.arcId!;
    const label = (arc.dataset.label ?? '').toLowerCase();
    let sel = false;
    if (arcId.startsWith('outer')) {
      sel = label === 'outros' ? selectedStackOthers : selectedStacks.has(label);
    } else if (arcId.startsWith('mid')) {
      sel = selectedMidFilters.has(label === 'internacional' ? 'internacional' : 'nacional');
    } else if (arcId.startsWith('inner')) {
      sel = selectedInnerFilters.has(label.includes('linkedin') ? 'linkedin' : 'outros');
    }
    arc.classList.toggle('ws-arc-sel',   sel);
    arc.classList.toggle('ws-arc-unsel', !sel && anySelected);
  });
  document.querySelectorAll<HTMLElement>('.ws-leg-item').forEach(item => {
    const arcId = item.dataset.arcId ?? '';
    const arc   = document.querySelector<SVGPathElement>(`.ws-arc[data-arc-id="${arcId}"]`);
    const sel   = arc?.classList.contains('ws-arc-sel') ?? false;
    item.classList.toggle('ws-leg-sel',   sel);
    item.classList.toggle('ws-leg-unsel', !sel && anySelected);
  });
}

document.getElementById('sf-toggle')?.addEventListener('click', () => setSfOpen(!sfOpen));

document.querySelectorAll<HTMLButtonElement>('.sf-tag').forEach(tag => {
  tag.addEventListener('click', () => {
    const v = tag.dataset.stack!;
    if (selectedStacks.has(v)) { selectedStacks.delete(v); tag.classList.remove('on'); }
    else                        { selectedStacks.add(v);    tag.classList.add('on'); }
    updateSfCount();
    syncArcVisuals();
    applyFilters();
    syncJpStackChips();
  });
});

function syncJpStackChips() {
  document.querySelectorAll<HTMLElement>('#jp-stack [data-stack]').forEach(chip => {
    chip.classList.toggle('jp-chip-active', selectedStacks.has(chip.dataset.stack!));
  });
}

document.getElementById('jp-stack')?.addEventListener('click', e => {
  const chip = (e.target as HTMLElement).closest<HTMLElement>('[data-stack]');
  if (!chip) return;
  const v = chip.dataset.stack!;
  const sfTag = document.querySelector<HTMLButtonElement>(`.sf-tag[data-stack="${v}"]`);
  if (selectedStacks.has(v)) {
    selectedStacks.delete(v);
    chip.classList.remove('jp-chip-active');
    if (sfTag) sfTag.classList.remove('on');
  } else {
    selectedStacks.add(v);
    chip.classList.add('jp-chip-active');
    if (sfTag) sfTag.classList.add('on');
    if (!sfOpen) setSfOpen(true);
  }
  updateSfCount();
  syncArcVisuals();
  applyFilters();
});

// ── Filter logic ───────────────────────────────────────────────
let searchQ = _q0.toLowerCase();

function applyFilters() {
  let visible = 0;
  document.querySelectorAll<HTMLElement>('.job-row').forEach(row => {
    const hay = row.dataset.search ?? '';
    const rem = row.dataset.remote === 'true';
    const matchSearch = !searchQ || hay.includes(searchQ);
    const matchUrlStack = _stacks.length === 0 || _stacks.some(s => hay.includes(s));
    // Outer ring (stack dimension): OR between all selected stack categories
    const outerAnySelected = selectedStacks.size > 0 || selectedStackOthers;
    const matchOuterStack = !outerAnySelected || (
      (selectedStacks.size > 0 && [...selectedStacks].some(s => hay.includes(s))) ||
      (selectedStackOthers && !top4Labels.some(s => hay.includes(s)))
    );
    const matchStack  = matchUrlStack && matchOuterStack;
    const matchNivel  = _niveis.length === 0 || _niveis.some(n => hay.includes(n));
    const matchModo   = _modos.length  === 0 || _modos.some(m =>
      m === 'remoto' ? (rem || hay.includes('remoto')) : hay.includes(m));
    const matchExtras = _extras.length === 0 || _extras.every(e => {
      if (e === 'internacional') return row.dataset.internacional === 'true';
      if (e === 'nacional')      return row.dataset.internacional !== 'true';
      if (e === 'linkedin')      return row.dataset.linkedin === 'true';
      return true;
    });
    const matchMidFilter    = selectedMidFilters.size === 0 || selectedMidFilters.size >= 2 ||
      (selectedMidFilters.has('internacional')
        ? row.dataset.internacional === 'true'
        : row.dataset.internacional !== 'true');
    const matchInnerFilter  = selectedInnerFilters.size === 0 || selectedInnerFilters.size >= 2 ||
      (selectedInnerFilters.has('linkedin')
        ? row.dataset.linkedin === 'true'
        : row.dataset.linkedin !== 'true');
    const show = matchSearch && matchStack && matchNivel && matchModo && matchExtras
               && matchMidFilter && matchInnerFilter;
    row.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  const countEl = document.querySelector('.exp-count');
  if (countEl) countEl.textContent = String(visible);
}

let searchTimer: ReturnType<typeof setTimeout>;
document.getElementById('search')?.addEventListener('input', e => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => {
    searchQ = (e.target as HTMLInputElement).value.toLowerCase().trim();
    applyFilters();
  }, 150);
});

// Apply initial URL filters
if (_q0 || _stacks.length || _niveis.length || _modos.length) {
  applyFilters();
}

// ── Preview panel logic ────────────────────────────────────────
let selectedId: number | null = null;

// Embedded job data as JSON (passed from Astro)
const jobsData: any[] = JSON.parse(document.getElementById('jobs-data')?.textContent ?? '[]');
const jobsMap = Object.fromEntries(jobsData.map(j => [j.id, j]));

function initials(name: string) {
  return name.split(/\s+/).slice(0,2).map((w: string) => w[0]).join('').toUpperCase().slice(0,2) || '??';
}


function renderDesc(raw: string): string {
  return raw
    .replace(/###\s*(.+)/g, '<h3>$1</h3>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>[\s\S]+?<\/li>)+/g, m => `<ul>${m}</ul>`)
    .replace(/\n\n+/g, '</p><p>')
    .replace(/^(?!<[hup])(.+)$/gm, '$1');
}

const STACK_PALETTE = [
  { color: '#00ff9d', bg: 'rgba(0,255,157,0.07)',  borderDim: 'rgba(0,255,157,0.15)',  borderLeft: 'rgba(0,255,157,0.75)'  },
  { color: '#00d4ff', bg: 'rgba(0,212,255,0.07)',  borderDim: 'rgba(0,212,255,0.15)',  borderLeft: 'rgba(0,212,255,0.75)'  },
  { color: '#ffd700', bg: 'rgba(255,215,0,0.07)',  borderDim: 'rgba(255,215,0,0.15)',  borderLeft: 'rgba(255,215,0,0.75)'  },
  { color: '#a78bfa', bg: 'rgba(167,139,250,0.07)', borderDim: 'rgba(167,139,250,0.15)', borderLeft: 'rgba(167,139,250,0.75)' },
  { color: '#60a5fa', bg: 'rgba(96,165,250,0.07)', borderDim: 'rgba(96,165,250,0.15)', borderLeft: 'rgba(96,165,250,0.75)' },
  { color: '#f87171', bg: 'rgba(248,113,113,0.07)', borderDim: 'rgba(248,113,113,0.15)', borderLeft: 'rgba(248,113,113,0.75)' },
];
function stackColor(name: string) {
  let h = 0;
  for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) & 0xffff;
  return STACK_PALETTE[h % STACK_PALETTE.length];
}

function showPreview(job: any) {
  const preview = document.getElementById('job-preview')!;
  const welcome = document.getElementById('welcome-state')!;

  welcome.style.display  = 'none';
  preview.style.display  = 'block';

  // animate
  preview.style.animation = 'none';
  void preview.offsetWidth;
  preview.style.animation = '';

  const applyHref = job.aplicar?.startsWith('http') ? job.aplicar : `https://${job.aplicar}`;

  document.getElementById('jp-avatar')!.textContent = initials(job.empresa || job.author?.login || '');
  document.getElementById('jp-title')!.textContent  = job.nivel ? `${job.title} (${job.nivel})` : job.title;
  const co = job.empresa || '';
  document.getElementById('jp-company')!.textContent = job.local ? `${co} (${job.local})` : co;

  const salaryInline = document.getElementById('jp-salary-inline') as HTMLElement;
  if (job.salario) {
    salaryInline.textContent = `~ ${job.salario}`;
    salaryInline.style.display = 'block';
  } else {
    salaryInline.style.display = 'none';
  }

  const badges = document.getElementById('jp-badges')!;
  badges.innerHTML = (job.labels || []).slice(0,3)
    .map((l: string) => `<span class="jp-badge">${l}</span>`).join('');

  const modeloEl = document.getElementById('jp-modelo')!;
  modeloEl.innerHTML = job.isRemote
    ? `<span class="jr-tag remote">remoto</span>`
    : /híbrido|hibrido/i.test(job.tipo ?? '')
      ? `<span class="jr-tag hibrido">híbrido</span>`
      : /presencial/i.test(job.tipo ?? '')
        ? `<span class="jr-tag presencial">presencial</span>`
        : job.tipo
          ? `<span class="jr-tag">${job.tipo}</span>`
          : '';

  (document.getElementById('jp-detail') as HTMLAnchorElement).href  = `${import.meta.env.BASE_URL}vaga/${job.id}`;

  const stack = document.getElementById('jp-stack')!;
  stack.innerHTML = (job.stack || []).map((s: string) => {
    const c = stackColor(s);
    const key = s.toLowerCase();
    const active = selectedStacks.has(key) ? ' jp-chip-active' : '';
    return `<span class="jr-tag jp-chip-clickable${active}" data-stack="${key}" style="border-color:${c.borderLeft};color:${c.color}" title="Filtrar por ${s}">${s}</span>`;
  }).join('');

  const desc = document.getElementById('jp-desc')!;
  desc.innerHTML = job.descricao ? renderDesc(job.descricao) : '<p style="color:var(--muted)">Sem descrição — veja a Issue no GitHub.</p>';

  const candidaturaLabel = document.getElementById('jp-candidatura-label') as HTMLElement;
  const candidaturaEl    = document.getElementById('jp-candidatura')!;
  if (job.aplicar) {
    candidaturaLabel.style.display = '';
    candidaturaEl.innerHTML = `<div class="jp-copy-row">
      <span class="jp-copy-val">${job.aplicar}</span>
      <button class="jp-copy-btn" onclick="navigator.clipboard.writeText('${job.aplicar.replace(/'/g, "\\'")}').then(()=>{this.textContent='✓';this.classList.add('copied');setTimeout(()=>{this.textContent='⎘ copiar';this.classList.remove('copied')},1500)})">⎘ copiar</button>
    </div>`;
  } else {
    candidaturaLabel.style.display = 'none';
    candidaturaEl.innerHTML = '';
  }
}

// ── Chart interaction ──────────────────────────────────────────
const wsCallout  = document.getElementById('ws-callout')!;
const wsClR      = document.getElementById('ws-cl-r') as SVGLineElement | null;
const wsClH      = document.getElementById('ws-cl-h') as SVGLineElement | null;
const wsCd       = document.getElementById('ws-cd')   as SVGCircleElement | null;
const wsCtName   = document.getElementById('ws-ct-name') as SVGTextElement | null;
const wsCtPct    = document.getElementById('ws-ct-pct')  as SVGTextElement | null;

function showCallout(arc: SVGPathElement) {
  const midDeg = parseFloat(arc.dataset.midDeg!);
  const r      = parseFloat(arc.dataset.r!);
  const sw     = parseFloat(arc.dataset.sw!);
  const color  = arc.dataset.color!;
  const label  = arc.dataset.label!;
  const pct    = arc.dataset.pct!;
  const rad    = (midDeg - 90) * Math.PI / 180;
  const outerR = r + sw / 2 + 5;
  const extR   = outerR + 26;
  const x1 = outerR * Math.cos(rad), y1 = outerR * Math.sin(rad);
  const x2 = extR   * Math.cos(rad), y2 = extR   * Math.sin(rad);
  const dir = x2 >= 0 ? 1 : -1;
  const x3 = x2 + dir * 28, y3 = y2;
  const tx = x3 + dir * 5;
  wsClR?.setAttribute('x1', String(x1.toFixed(2))); wsClR?.setAttribute('y1', String(y1.toFixed(2)));
  wsClR?.setAttribute('x2', String(x2.toFixed(2))); wsClR?.setAttribute('y2', String(y2.toFixed(2)));
  wsClR?.setAttribute('stroke', color);
  wsClH?.setAttribute('x1', String(x2.toFixed(2))); wsClH?.setAttribute('y1', String(y2.toFixed(2)));
  wsClH?.setAttribute('x2', String(x3.toFixed(2))); wsClH?.setAttribute('y2', String(y3.toFixed(2)));
  wsClH?.setAttribute('stroke', color);
  wsCd?.setAttribute('cx', String(x1.toFixed(2))); wsCd?.setAttribute('cy', String(y1.toFixed(2)));
  wsCd?.setAttribute('fill', color);
  const anchor = dir > 0 ? 'start' : 'end';
  wsCtName?.setAttribute('x', String(tx.toFixed(2))); wsCtName?.setAttribute('y', String((y3 - 5).toFixed(2)));
  wsCtName?.setAttribute('text-anchor', anchor); wsCtName?.setAttribute('fill', color);
  wsCtName!.textContent = label;
  wsCtPct?.setAttribute('x', String(tx.toFixed(2))); wsCtPct?.setAttribute('y', String((y3 + 8).toFixed(2)));
  wsCtPct?.setAttribute('text-anchor', anchor);
  wsCtPct!.textContent = `${pct}%`;
  wsCallout.style.display = 'block';
}

document.querySelectorAll<SVGPathElement>('.ws-arc').forEach(arc => {
  arc.addEventListener('mouseenter', () => {
    const arcId = arc.dataset.arcId!;
    // Suspend selection visuals temporarily during hover
    document.querySelectorAll('.ws-arc').forEach(a => a.classList.remove('ws-arc-sel', 'ws-arc-unsel'));
    document.querySelectorAll('.ws-leg-item').forEach(item => item.classList.remove('ws-leg-sel', 'ws-leg-unsel'));
    showCallout(arc);
    document.querySelectorAll<SVGPathElement>('.ws-arc').forEach(a => {
      a.classList.toggle('ws-arc-hi',  a === arc);
      a.classList.toggle('ws-arc-dim', a !== arc);
    });
    document.querySelectorAll<HTMLElement>('.ws-leg-item').forEach(item => {
      const match = item.dataset.arcId === arcId;
      item.classList.toggle('ws-leg-hi',  match);
      item.classList.toggle('ws-leg-dim', !match);
    });
  });

  arc.addEventListener('mouseleave', () => {
    wsCallout.style.display = 'none';
    document.querySelectorAll('.ws-arc').forEach(a => a.classList.remove('ws-arc-hi', 'ws-arc-dim'));
    document.querySelectorAll('.ws-leg-item').forEach(item => item.classList.remove('ws-leg-hi', 'ws-leg-dim'));
    syncArcVisuals();
  });

  arc.addEventListener('click', () => {
    const arcId    = arc.dataset.arcId!;
    const label    = arc.dataset.label!;
    const labelLow = label.toLowerCase();
    if (arcId.startsWith('outer')) {
      if (labelLow === 'outros') {
        selectedStackOthers = !selectedStackOthers;
      } else {
        const key = labelLow;
        if (selectedStacks.has(key)) {
          selectedStacks.delete(key);
          document.querySelector<HTMLButtonElement>(`.sf-tag[data-stack="${key}"]`)?.classList.remove('on');
        } else {
          selectedStacks.add(key);
          const tag = document.querySelector<HTMLButtonElement>(`.sf-tag[data-stack="${key}"]`);
          if (tag) { tag.classList.add('on'); if (!sfOpen) setSfOpen(true); }
        }
        updateSfCount();
      }
    } else if (arcId.startsWith('mid')) {
      const key = labelLow === 'internacional' ? 'internacional' : 'nacional';
      if (selectedMidFilters.has(key)) selectedMidFilters.delete(key);
      else selectedMidFilters.add(key);
    } else if (arcId.startsWith('inner')) {
      const key = labelLow.includes('linkedin') ? 'linkedin' : 'outros';
      if (selectedInnerFilters.has(key)) selectedInnerFilters.delete(key);
      else selectedInnerFilters.add(key);
    }
    syncArcVisuals();
    applyFilters();
  });
});

// Legend items also clickable (delegates to arc click)
document.querySelectorAll<HTMLElement>('.ws-leg-item').forEach(item => {
  item.addEventListener('click', () => {
    const arcId = item.dataset.arcId;
    if (!arcId) return;
    document.querySelector<SVGPathElement>(`.ws-arc[data-arc-id="${arcId}"]`)
      ?.dispatchEvent(new MouseEvent('click'));
  });
});

// Click on row
document.querySelectorAll<HTMLElement>('.job-row').forEach(row => {
  row.addEventListener('click', e => {
    e.preventDefault();
    const id = Number(row.dataset.id);
    document.querySelectorAll('.job-row').forEach(r => r.classList.remove('selected'));
    row.classList.add('selected');
    selectedId = id;

    const job = jobsMap[id];
    if (job) showPreview(job);
  });
});

// Keyboard navigation
document.addEventListener('keydown', e => {
  if (e.key === '/') {
    e.preventDefault();
    (document.getElementById('search') as HTMLInputElement)?.focus();
    return;
  }
  const rows = [...document.querySelectorAll<HTMLElement>('.job-row:not(.hidden)')];
  if (!rows.length) return;
  const idx = rows.findIndex(r => r.classList.contains('selected'));

  if (e.key === 'ArrowDown') {
    e.preventDefault();
    const next = rows[idx + 1] || rows[0];
    next?.click();
    next?.scrollIntoView({ block: 'nearest' });
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    const prev = rows[idx - 1] || rows[rows.length - 1];
    prev?.click();
    prev?.scrollIntoView({ block: 'nearest' });
  } else if (e.key === 'Enter' && selectedId) {
    window.location.href = `${import.meta.env.BASE_URL}vaga/${selectedId}`;
  }
});
</script>

