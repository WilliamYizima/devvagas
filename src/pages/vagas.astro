---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchJobs } from '../lib/github';

const jobs = await fetchJobs();

const stackFreq = new Map<string, number>();
jobs.forEach(j => j.stack.forEach(s => stackFreq.set(s, (stackFreq.get(s) || 0) + 1)));
const allStacks = [...stackFreq.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([s]) => s);

// ── Chart data ──────────────────────────────────────────────────
const chartTotal = jobs.length;

function describeArc(r: number, startPct: number, endPct: number): string {
  const GAP = 0.7;
  const startDeg = startPct * 3.6 + GAP;
  const endDeg   = endPct   * 3.6 - GAP;
  if (endDeg <= startDeg) return '';
  const rad = (d: number) => (d - 90) * Math.PI / 180;
  const x1 = r * Math.cos(rad(startDeg)), y1 = r * Math.sin(rad(startDeg));
  const x2 = r * Math.cos(rad(endDeg)),   y2 = r * Math.sin(rad(endDeg));
  const large = (endDeg - startDeg) > 180 ? 1 : 0;
  return `M${x1.toFixed(2)},${y1.toFixed(2)} A${r},${r} 0 ${large},1 ${x2.toFixed(2)},${y2.toFixed(2)}`;
}

interface Seg { label: string; pct: number; color: string; }
function buildRing(segs: Seg[], r: number, sw: number, prefix: string) {
  let cur = 0;
  return segs.map((s, i) => {
    const st = cur; cur += s.pct;
    const midDeg = ((st + cur) / 2) * 3.6;
    return { ...s, path: describeArc(r, st, cur), midDeg, r, sw, arcId: `${prefix}-${i}` };
  });
}

// Outer ring: top 4 stacks
const SCOL = ['#00ff9d', '#00d4ff', '#fbbf24', '#f87171', '#3f4756'];
const sfSorted = [...stackFreq.entries()].sort((a, b) => b[1] - a[1]);
const sfTotal  = sfSorted.reduce((a, [, c]) => a + c, 0);
const top4 = sfSorted.slice(0, 4).map(([label, count], i) => ({
  label, pct: sfTotal ? Math.round(count / sfTotal * 100) : 0, color: SCOL[i],
}));
const othersPct = sfTotal ? 100 - top4.reduce((a, s) => a + s.pct, 0) : 0;
if (othersPct > 0) top4.push({ label: 'Outros', pct: othersPct, color: SCOL[4] });
const outerRing = buildRing(top4, 136, 20, 'outer');

// Middle ring: Internacional vs Nacional
const intlCount = jobs.filter(j => (j as any).isInternacional).length;
const intlPct   = chartTotal ? Math.round(intlCount / chartTotal * 100) : 0;
const midRing   = buildRing([
  { label: 'Internacional', pct: intlPct,           color: '#00ff9d' },
  { label: 'Nacional',      pct: 100 - intlPct,     color: '#00d4ff' },
], 108, 18, 'mid');

// Inner ring: LinkedIn vs Outros
const liCount = jobs.filter(j => (j as any).isLinkedin).length;
const liPct   = chartTotal ? Math.round(liCount / chartTotal * 100) : 0;
const innerRing = buildRing([
  { label: 'Via LinkedIn', pct: liPct,        color: '#0ea5e9' },
  { label: 'Outros',       pct: 100 - liPct,  color: '#a78bfa' },
], 82, 16, 'inner');


function timeAgo(d: string) {
  const s = (Date.now() - new Date(d).getTime()) / 1000;
  if (s < 3600)    return `${Math.floor(s/60)}m`;
  if (s < 86400)   return `${Math.floor(s/3600)}h`;
  if (s < 2592000) return `${Math.floor(s/86400)}d`;
  return new Date(d).toLocaleDateString('pt-BR', { day:'2-digit', month:'short' });
}
---

<BaseLayout title="Vagas" activeSection="vagas" breadcrumb="vagas/index.ts">

<div class="ide-layout">

  <!-- LEFT: File Explorer / Job List -->
  <aside class="explorer" id="explorer">

    <div class="exp-header">
      <span class="exp-title">VAGAS ABERTAS</span>
      <span class="exp-count">{jobs.length}</span>
    </div>

    <!-- Search + Filters -->
    <div class="exp-search">
      <div class="search-wrap">
        <span class="search-ico">⌕</span>
        <input id="search" type="search" placeholder="nome da vaga ou empresa..." autocomplete="off" />
      </div>
    </div>

    <!-- Stack filter (collapsível) -->
    <div class="stack-filter-wrap">
      <div class="sf-header" id="sf-toggle" role="button" tabindex="0">
        <span class="sf-label">// stack</span>
        <span class="sf-sel-count" id="sf-sel-count"></span>
        <span class="sf-line"></span>
        <span class="sf-chevron" id="sf-chevron">▾</span>
      </div>
      <div class="sf-body" id="sf-body">
        <div class="sf-tags">
          {allStacks.map(s => (
            <button class="sf-tag" data-stack={s.toLowerCase()}>{s}</button>
          ))}
        </div>
      </div>
    </div>

    <!-- Job rows -->
    <div class="job-rows" id="job-rows">
      {jobs.map((job, i) => (
        <a
          href={`${import.meta.env.BASE_URL}vaga/${job.id}`}
          class="job-row"
          data-id={job.id}
          data-search={`${job.title} ${job.empresa} ${job.stack.join(' ')} ${job.labels.join(' ')} ${job.nivel} ${job.tipo}`.toLowerCase()}
          data-remote={job.isRemote ? 'true' : 'false'}
          data-internacional={job.isInternacional ? 'true' : 'false'}
          data-linkedin={job.isLinkedin ? 'true' : 'false'}
          style={`animation-delay:${i * 0.04}s`}
        >
          <div class="jr-top">
            <span class="jr-company">
              {job.isLinkedin && (
                <svg class="jr-li-icon" viewBox="0 0 24 24" fill="currentColor" aria-label="LinkedIn">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
              {job.empresa || job.author.login}{job.local ? ` (${job.local})` : ''}
            </span>
            <span class="jr-time">{timeAgo(job.createdAt)}</span>
          </div>
          <div class="jr-title">{job.nivel ? `${job.title} (${job.nivel})` : job.title}</div>
          <div class="jr-meta">
            {job.isRemote
              ? <span class="jr-tag remote">remoto</span>
              : /híbrido|hibrido/i.test(job.tipo ?? '')
                ? <span class="jr-tag hibrido">híbrido</span>
                : /presencial/i.test(job.tipo ?? '')
                  ? <span class="jr-tag presencial">presencial</span>
                  : (job.tipo || job.local) && <span class="jr-tag">{job.tipo || job.local}</span>}
            {job.nivel && <span class="jr-tag nivel">{job.nivel}</span>}
            {job.isInternacional && <span class="jr-tag intl">internacional</span>}
            {job.salario && <span class="jr-salary">{job.salario}</span>}
          </div>
        </a>
      ))}
    </div>

  </aside>

  <!-- RIGHT: Preview panel -->
  <section class="preview-panel" id="preview-panel">

    <!-- Welcome state — chart overview -->
    <div class="welcome-state" id="welcome-state">
      <div class="ws-chart">

        <svg viewBox="-160 -160 320 320" class="ws-svg">
          <!-- Background tracks -->
          <circle r="136" cx="0" cy="0" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="20"/>
          <circle r="108" cx="0" cy="0" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="18"/>
          <circle r="82"  cx="0" cy="0" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="16"/>

          <!-- Outer ring: stacks -->
          {outerRing.filter(s => s.path).map(s => (
            <path
              d={s.path} fill="none" stroke={s.color}
              stroke-width="20" stroke-linecap="round"
              class="ws-arc"
              data-arc-id={s.arcId}
              data-mid-deg={s.midDeg.toFixed(1)}
              data-r={s.r} data-sw={s.sw}
              data-color={s.color} data-label={s.label} data-pct={s.pct}
            />
          ))}

          <!-- Middle ring: internacional -->
          {midRing.filter(s => s.path).map(s => (
            <path
              d={s.path} fill="none" stroke={s.color}
              stroke-width="18" stroke-linecap="round"
              class="ws-arc"
              data-arc-id={s.arcId}
              data-mid-deg={s.midDeg.toFixed(1)}
              data-r={s.r} data-sw={s.sw}
              data-color={s.color} data-label={s.label} data-pct={s.pct}
            />
          ))}

          <!-- Inner ring: linkedin -->
          {innerRing.filter(s => s.path).map(s => (
            <path
              d={s.path} fill="none" stroke={s.color}
              stroke-width="16" stroke-linecap="round"
              class="ws-arc"
              data-arc-id={s.arcId}
              data-mid-deg={s.midDeg.toFixed(1)}
              data-r={s.r} data-sw={s.sw}
              data-color={s.color} data-label={s.label} data-pct={s.pct}
            />
          ))}

          <!-- Center decorative ring -->
          <circle r="54" cx="0" cy="0" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

          <!-- Center -->
          <text x="0" y="-6" text-anchor="middle" class="ws-cnum">{chartTotal}</text>
          <text x="0" y="16" text-anchor="middle" class="ws-csub">vagas abertas</text>

          <!-- Callout (shown on arc hover via JS) -->
          <g id="ws-callout" style="display:none; pointer-events:none">
            <line id="ws-cl-r" stroke-width="1" stroke-linecap="round" opacity="0.8"/>
            <line id="ws-cl-h" stroke-width="1" stroke-linecap="round" opacity="0.8"/>
            <circle id="ws-cd" r="3"/>
            <text id="ws-ct-name" class="ws-ct-name" dominant-baseline="auto"/>
            <text id="ws-ct-pct"  class="ws-ct-pct"  dominant-baseline="auto"/>
          </g>
        </svg>

        <p class="ws-hint">◈ selecione no gráfico ou na legenda para filtrar</p>

        <!-- Legends -->
        <div class="ws-legs">
          <div class="ws-leg-group">
            <div class="ws-leg-title">// stack</div>
            {outerRing.map(s => (
              <div class="ws-leg-item" data-arc-id={s.arcId}>
                <span class="ws-leg-bar" style={`background:${s.color};box-shadow:0 0 4px ${s.color}`}></span>
                <span class="ws-leg-name">{s.label}</span>
                <span class="ws-leg-pct">{s.pct}%</span>
              </div>
            ))}
          </div>
          <div class="ws-leg-group">
            <div class="ws-leg-title">// distribuição</div>
            {midRing.map(s => (
              <div class="ws-leg-item" data-arc-id={s.arcId}>
                <span class="ws-leg-bar" style={`background:${s.color};box-shadow:0 0 4px ${s.color}`}></span>
                <span class="ws-leg-name">{s.label}</span>
                <span class="ws-leg-pct">{s.pct}%</span>
              </div>
            ))}
          </div>
          <div class="ws-leg-group">
            <div class="ws-leg-title">// origem</div>
            {innerRing.map(s => (
              <div class="ws-leg-item" data-arc-id={s.arcId}>
                <span class="ws-leg-bar" style={`background:${s.color};box-shadow:0 0 4px ${s.color}`}></span>
                <span class="ws-leg-name">{s.label}</span>
                <span class="ws-leg-pct">{s.pct}%</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

    <!-- Job preview (populated by JS) -->
    <div class="job-preview" id="job-preview" style="display:none">
      <!-- header -->
      <div class="jp-header">
        <div class="jp-avatar" id="jp-avatar">NU</div>
        <div class="jp-info">
          <h2 class="jp-title" id="jp-title">—</h2>
          <p class="jp-company" id="jp-company">—</p>
          <p class="jp-salary-inline" id="jp-salary-inline" style="display:none"></p>
          <div class="jp-badges" id="jp-badges"></div>
        </div>
        <div class="jp-actions">
          <a class="jp-detail-link" id="jp-detail" href="#">ver detalhe completo ↗</a>
        </div>
      </div>

      <!-- modelo de trabalho -->
      <div class="jp-section-label">// modelo de trabalho</div>
      <div class="jp-vaga" id="jp-modelo"></div>

      <!-- stack -->
      <div class="jp-section-label">// stack</div>
      <div class="jp-stack" id="jp-stack"></div>

      <!-- description preview -->
      <div class="jp-section-label">// descrição</div>
      <div class="jp-desc" id="jp-desc"></div>
      <br>
      <!-- candidatar-se -->
      <div class="jp-section-label jp-candidatura-label" id="jp-candidatura-label" style="display:none">// candidatar-se</div>
      <div class="jp-candidatura" id="jp-candidatura"></div>
    </div>

  </section>

</div>

</BaseLayout>

<style>
/* ── IDE LAYOUT ──────────────────────────────────────────── */
.ide-layout {
  display: grid;
  grid-template-columns: 300px 1fr;
  height: calc(100vh - 36px - 24px);
  overflow: hidden;
}

/* ── EXPLORER ────────────────────────────────────────────── */
.explorer {
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--darker);
}

.exp-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.75rem 1rem 0.5rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.exp-title {
  font-size: 0.55rem; text-transform: uppercase;
  letter-spacing: 0.15em; color: var(--muted);
}
.exp-count {
  font-size: 0.6rem; color: var(--green);
  background: rgba(0,255,157,0.08);
  border: 1px solid rgba(0,255,157,0.2);
  padding: 0.1rem 0.4rem;
}

.exp-search { padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--border); flex-shrink: 0; }

.search-wrap {
  display: flex; align-items: center; gap: 0.5rem;
  background: var(--dark); border: 1px solid var(--border2);
  padding: 0.35rem 0.6rem;
  transition: border-color 0.15s;
}
.search-wrap:focus-within { border-color: var(--green); }
.search-ico { font-size: 0.9rem; color: var(--muted); }
#search {
  flex: 1; background: none; border: none; outline: none;
  font-family: var(--font); font-size: 0.72rem; color: var(--text);
}
#search::placeholder { color: var(--muted); }

/* Job rows */
.job-rows {
  flex: 1; overflow-y: auto; padding: 0.25rem 0;
}

.job-row {
  display: block;
  padding: 0.7rem 1rem;
  border-left: 2px solid transparent;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background 0.12s, border-color 0.12s;
  animation: rowIn 0.3s ease both;
  text-decoration: none; color: inherit;
}
@keyframes rowIn { from { opacity:0; transform:translateX(-6px); } to { opacity:1; transform:none; } }

.job-row:hover { background: var(--mid); border-left-color: var(--border2); }
.job-row.selected { background: var(--dark); border-left-color: var(--green); }
.job-row.hidden { display: none; }

.jr-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.2rem; }
.jr-company { font-size: 0.62rem; color: var(--muted); display: flex; align-items: center; gap: 0.3rem; }
.jr-li-icon { width: 10px; height: 10px; color: #0a66c2; flex-shrink: 0; }
.jr-time    { font-size: 0.58rem; color: var(--muted2); }
.jr-title   { font-size: 0.78rem; color: var(--text); margin-bottom: 0.4rem; line-height: 1.3; font-weight: 500; }
.jr-meta    { display: flex; align-items: center; gap: 0.3rem; flex-wrap: wrap; }

:global(.jr-tag) {
  font-size: 0.58rem; padding: 0.1rem 0.4rem;
  border: 1px solid var(--border2); color: var(--muted);
  border-radius: 2px;
}
:global(.jr-tag.remote)    { border-color: rgba(0,255,157,0.3);   color: var(--green); }
:global(.jr-tag.nivel)     { border-color: rgba(0,212,255,0.3);   color: var(--cyan); }
:global(.jr-tag.hibrido)   { border-color: rgba(251,191,36,0.35); color: #fbbf24; }
:global(.jr-tag.presencial){ border-color: rgba(167,139,250,0.35);color: #a78bfa; }
:global(.jr-tag.intl)      { border-color: rgba(14,165,233,0.35); color: #0ea5e9; }
.jr-salary        { margin-left: auto; font-size: 0.6rem; color: var(--green); }

/* ── STACK FILTER ────────────────────────────────────────── */
.stack-filter-wrap {
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.sf-header {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.45rem 0.75rem;
  cursor: pointer; user-select: none;
}
.sf-header:hover .sf-label { color: var(--text); }

.sf-label {
  font-size: 0.58rem; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--muted);
  white-space: nowrap;
}

.sf-sel-count {
  font-size: 0.5rem; background: rgba(0,255,157,0.12);
  border: 1px solid rgba(0,255,157,0.3); color: var(--green);
  padding: 0.05rem 0.35rem; min-width: 1rem; text-align: center;
}

.sf-line { flex: 1; height: 1px; background: var(--border); }

.sf-chevron {
  font-size: 0.65rem; color: var(--muted);
  transition: transform 0.2s;
}
.sf-chevron.open { transform: rotate(180deg); }

.sf-body { display: none; padding: 0 0.75rem 0.6rem; max-height: 180px; overflow-y: auto; }

.sf-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

.sf-tag {
  background: var(--mid);
  border: 1px solid var(--border2);
  color: var(--muted2);
  font-family: var(--font);
  font-size: 0.6rem;
  padding: 0.25rem 0.6rem;
  cursor: pointer;
  transition: all 0.15s;
}
.sf-tag:hover { border-color: var(--cyan); color: var(--cyan); background: rgba(0,212,255,0.06); }
.sf-tag.on {
  background: rgba(0,255,157,0.1);
  border-color: var(--green);
  color: var(--green);
  font-weight: 600;
}

/* ── PREVIEW PANEL ───────────────────────────────────────── */
.preview-panel {
  overflow-y: auto;
  background: var(--black);
  position: relative;
}

/* WELCOME STATE — CHART */
.welcome-state {
  height: 100%;
  display: flex; align-items: center; justify-content: center;
  padding: 2rem;
}

.ws-chart {
  display: flex; flex-direction: column;
  align-items: center; gap: 1.75rem;
  animation: wsIn 0.5s ease both;
}
@keyframes wsIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: none; }
}

.ws-svg { width: 320px; height: 320px; overflow: visible; }

/* Arc glow + interaction */
.ws-arc {
  filter: drop-shadow(0 0 5px currentColor);
  transition: filter 0.2s, opacity 0.2s;
  opacity: 0.9;
  cursor: pointer;
}
.ws-arc.ws-arc-hi  { filter: drop-shadow(0 0 14px currentColor); opacity: 1; }
.ws-arc.ws-arc-dim  { filter: none; opacity: 0.18; }
.ws-arc.ws-arc-sel  { filter: drop-shadow(0 0 12px currentColor); opacity: 1; }
.ws-arc.ws-arc-unsel{ filter: none; opacity: 0.22; }

/* Callout */
.ws-ct-name {
  font-size: 10px; font-family: var(--font); font-weight: 600;
}
.ws-ct-pct {
  font-size: 9px; font-family: var(--font);
  fill: rgba(255,255,255,0.5);
}

.ws-cnum {
  font-family: var(--display); font-size: 34px; font-weight: 900;
  fill: var(--text); letter-spacing: 0.04em;
}
.ws-csub {
  font-family: var(--font); font-size: 8.5px;
  fill: var(--muted); text-transform: uppercase; letter-spacing: 0.18em;
}

/* Legend */
.ws-hint {
  font-size: 0.56rem; color: var(--muted);
  letter-spacing: 0.1em; text-transform: uppercase;
  text-align: center; margin: -0.5rem 0 0;
  opacity: 0.7;
}

.ws-legs {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1.4rem 2.5rem; width: 100%; max-width: 580px;
}

.ws-leg-group { display: flex; flex-direction: column; gap: 0.65rem; }

.ws-leg-title {
  font-size: 0.56rem; text-transform: uppercase;
  letter-spacing: 0.12em; color: var(--muted);
  padding-bottom: 0.4rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 0.05rem;
  display: flex; align-items: center; justify-content: space-between;
}
.ws-leg-title::after {
  content: '↕ clique';
  font-size: 0.46rem; letter-spacing: 0.06em;
  color: var(--muted2); opacity: 0.5;
  text-transform: lowercase;
}

.ws-leg-item {
  display: flex; align-items: center; gap: 0.6rem;
  transition: opacity 0.15s;
  cursor: pointer;
}
.ws-leg-item.ws-leg-dim  { opacity: 0.2; }
.ws-leg-item.ws-leg-hi   { opacity: 1; }
.ws-leg-item.ws-leg-hi .ws-leg-name  { color: var(--text); font-weight: 600; }
.ws-leg-item.ws-leg-hi .ws-leg-pct   { color: var(--green); font-size: 0.78rem; }
.ws-leg-item.ws-leg-hi .ws-leg-bar   { width: 22px; }
.ws-leg-item.ws-leg-sel  { opacity: 1; }
.ws-leg-item.ws-leg-sel .ws-leg-name { color: var(--text); font-weight: 600; }
.ws-leg-item.ws-leg-sel .ws-leg-pct  { color: var(--green); font-size: 0.78rem; }
.ws-leg-item.ws-leg-sel .ws-leg-bar  { width: 22px; }
.ws-leg-item.ws-leg-unsel{ opacity: 0.2; }

.ws-leg-bar {
  width: 16px; height: 3px; border-radius: 2px; flex-shrink: 0;
  transition: width 0.2s;
}

.ws-leg-name {
  flex: 1; font-size: 0.68rem; color: var(--muted2);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

.ws-leg-pct {
