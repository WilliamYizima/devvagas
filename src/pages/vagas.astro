<script id="jobs-data" type="application/json" set:html={JSON.stringify(jobs)}></script>
<script id="chart-data" type="application/json" set:html={JSON.stringify({ top4: sfSorted.slice(0,4).map(([s]) => s.toLowerCase()) })}></script>
