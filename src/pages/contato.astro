---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contato" activeSection="contato" breadcrumb="contato/index.ts">

<div class="contact-shell">

  <div class="ct-tabs">
    <div class="ctab active"><span class="td ts"></span>contato.ts</div>
  </div>

  <div class="ct-area">
    <div class="ct-gutter" id="ct-gutter"></div>
    <div class="ct-content" id="ct-content">

      <span class="cl cm">// quer falar comigo?</span>
      <span class="cl"></span>
      <span class="cl"><span class="cb">const</span> <span class="ck">contato</span> = <span class="cb">{`{`}</span></span>
      <span class="cl">  <span class="ck">links</span><span class="cp">:</span> <a href="https://blog.whatwill.tech/about/" target="_blank" rel="noopener" class="cs">"blog.whatwill.tech/about/"</a><span class="cp">,</span></span>
      <span class="cl"><span class="cb">{`}`}</span><span class="cp">;</span></span>

      <div style="height:4rem"></div>
    </div>
  </div>
</div>

</BaseLayout>

<style>
.contact-shell {
  display: flex; flex-direction: column;
  height: calc(100vh - 36px - 24px);
}

.ct-tabs {
  display: flex; background: var(--darker);
  border-bottom: 1px solid var(--border); height: 36px; flex-shrink: 0;
}
.ctab {
  display: flex; align-items: center; gap: 0.4rem;
  padding: 0 1rem; height: 100%; font-size: 0.65rem; color: var(--text);
  border-right: 1px solid var(--border);
  border-top: 2px solid var(--purple);
  background: var(--black);
}
.td { width: 8px; height: 8px; border-radius: 50%; }
.td.ts { background: #3178c6; }

.ct-area { display: flex; flex: 1; overflow: hidden; }

.ct-gutter {
  width: 44px; background: var(--darker);
  border-right: 1px solid var(--border); flex-shrink: 0;
}

.ct-content {
  flex: 1; overflow-y: auto;
  padding: 1.5rem 2.5rem; max-width: 680px;
  display: flex; flex-direction: column;
}

.cl { font-size: 0.72rem; line-height: 1.9; display: block; white-space: pre-wrap; }
.cl.cm { color: var(--muted); font-style: italic; }
.ck { color: #9cdcfe; }
.cs { color: #ce9178; text-decoration: none; transition: opacity 0.15s; }
.cs:hover { opacity: 0.7; }
.cb { color: #569cd6; }
.cp { color: #d4d4d4; }
</style>

<script>
  const content = document.getElementById('ct-content')!;
  const gutter  = document.getElementById('ct-gutter')!;
  const lineH   = 0.72 * 16 * 1.9;
  const count   = Math.ceil((content.scrollHeight || 400) / lineH) + 10;
  gutter.innerHTML = Array.from({length: Math.max(count, 40)}, (_, i) =>
    `<div style="font-size:0.6rem;color:var(--muted2);text-align:right;padding-right:0.6rem;line-height:${lineH}px">${i+1}</div>`
  ).join('');
  content.addEventListener('scroll', () => { gutter.scrollTop = content.scrollTop; });
</script>
